// ========== AI CALLS ==========
async function callGroq(prompt) {
    const url = 'https://api.groq.com/openai/v1/chat/completions';
    const headers = { 'Authorization': `Bearer ${CONFIG.GROQ_KEY}`, 'Content-Type': 'application/json' };
    const payload = { model: 'gemma-7b-it', messages: [{ role: 'user', content: prompt }], temperature: 0.85, max_tokens: CONFIG.MAX_TOKENS };
    const resp = await fetch(url, { method: 'POST', headers, body: JSON.stringify(payload) });
    if (!resp.ok) throw new Error('Groq error');
    const data = await resp.json();
    return data?.choices?.[0]?.message?.content?.trim() || '';
}

async function callGemini(prompt) {
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${CONFIG.GEMINI_KEY}`;
    const payload = { contents: [{ parts: [{ text: prompt }] }] };
    try {
        const resp = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        if (!resp.ok) throw new Error('Gemini error');
        const data = await resp.json();
        return data?.candidates?.[0]?.content?.parts?.[0]?.text?.trim() || '';
    } catch(e) { return ''; }
}

async function callPollinations(prompt) {
    const resp = await fetch('https://text.pollinations.ai/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ messages: [{ role: 'user', content: prompt }] }) });
    return (await resp.text()).trim();
}

async function getAIResponse(prompt) {
    const key = prompt.slice(0, 200);
    if (aiCache.has(key)) {
        const cached = aiCache.get(key);
        if (Date.now() - cached.timestamp < 600000) return cached.response; // cache 10 menit
    }
    let response = '';
    try { if (CONFIG.GROQ_KEY && CONFIG.GROQ_KEY !== 'gsk_...') response = await callGroq(prompt); } catch(e) {}
    if (!response) try { if (CONFIG.GEMINI_KEY && CONFIG.GEMINI_KEY !== 'AIzaSy...') response = await callGemini(prompt); } catch(e) {}
    if (!response) try { response = await callPollinations(prompt); } catch(e) {}
    if (!response) response = '⚠️ AI sibuk, coba nanti.';
    aiCache.set(key, { response, timestamp: Date.now() });
    if (aiCache.size > 50) {
        const keys = [...aiCache.keys()];
        for (let i = 0; i < 10; i++) aiCache.delete(keys[i]);
    }
    return response;
}

// ========== WEB SEARCH ==========
async function webSearch(query) {
    const key = query.toLowerCase().trim();
    if (searchCache.has(key)) {
        const cached = searchCache.get(key);
        if (Date.now() - cached.timestamp < 3600000) return cached.content;
    }
    try {
        const duck = await fetch(`https://api.duckduckgo.com/?q=${encodeURIComponent(query)}&format=json&no_html=1`);
        const data = await duck.json();
        const content = data?.AbstractText || data?.RelatedTopics?.[0]?.Text || 'Tidak ada hasil.';
        searchCache.set(key, { content, timestamp: Date.now() });
        return content;
    } catch(e) { return 'Gagal cari.'; }
}

// ========== QUANTUM, EMOSI, BLOCKCHAIN ==========
function quantumCollapse(ego, trust) {
    const testProb = Math.min(0.9, Math.max(0.1, 0.3 + ego/200 + (100 - trust)/200));
    const helpProb = 1 - testProb;
    const tsundereProb = Math.min(0.95, Math.max(0.1, 0.3 + ego/150));
    const actualTsundere = testProb > 0.6 ? Math.min(0.95, tsundereProb + 0.2) : tsundereProb;
    const lapis1 = Math.random() < helpProb ? 0 : 1;
    const lapis2 = lapis1 === 0 ? (Math.random() < (1 - actualTsundere) ? 0 : 1) : (Math.random() < actualTsundere ? 1 : 0);
    return { lapis1, lapis2, style: lapis2 === 0 ? 'formal' : 'tsundere', alpha: helpProb, beta: testProb };
}

function updateEmotion(userData, userInput) {
    const lower = userInput.toLowerCase();
    const insultWords = ['bego','tolol','asu','goblok','jelek','dungu','idiot','bodoh','kampret','anjing','babi','kontol'];
    const praiseWords = ['cantik','pintar','keren','manis','sayang','ganteng','baik','hebat','jenius','sempurna'];
    const sadWords = ['sedih','kecewa','putus asa','menangis','rindu','kesepian','galau'];
    const happyWords = ['senang','gembira','bahagia','suka','terharu','semangat'];

    let deltaEgo = 0, deltaTrust = 0, newMood = userData.mood;
    if (insultWords.some(w => lower.includes(w))) { deltaEgo = 15; deltaTrust = -15; newMood = 'marah'; }
    else if (praiseWords.some(w => lower.includes(w))) { deltaEgo = -10; deltaTrust = 10; newMood = 'senang'; }
    else if (sadWords.some(w => lower.includes(w))) { deltaEgo = 0; deltaTrust = 5; newMood = 'sedih'; }
    else if (happyWords.some(w => lower.includes(w))) { deltaEgo = -5; deltaTrust = 5; newMood = 'gembira'; }
    else if (Math.random() < 0.05) {
        const moods = ['normal','gengsi','manja','santai','melankolis','filosofis'];
        newMood = moods[Math.floor(Math.random() * moods.length)];
    }
    userData.ego = Math.max(0, Math.min(100, userData.ego + deltaEgo));
    userData.trust = Math.max(0, Math.min(100, userData.trust + deltaTrust));
    userData.mood = newMood;
    userData.consciousness = Math.min(100, userData.consciousness + 1);
    return userData;
}

