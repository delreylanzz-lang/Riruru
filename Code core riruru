}

function sha256(str) {
    let hash = 0, i, chr;
    for (i = 0; i < str.length; i++) { chr = str.charCodeAt(i); hash = ((hash << 5) - hash) + chr; hash |= 0; }
    return Math.abs(hash).toString(16).padStart(64, '0');
}

function addBlock(chain, data) {
    const prev = chain[chain.length - 1] || { index: -1, hash: '0' };
    const block = { index: prev.index + 1, timestamp: new Date().toISOString(), data, prev_hash: prev.hash, hash: sha256(`${prev.index+1}|${prev.hash}|${data}`) };
    chain.push(block);
    return chain;
}

async function verifyUsdt(txHash, expected) {
    const url = `https://api.etherscan.io/api?module=account&action=tokentx&address=${CONFIG.WALLET_ADDRESS}&apikey=${CONFIG.ETHERSCAN_API_KEY}`;
    try {
        const resp = await fetch(url);
        const data = await resp.json();
        if (data.status !== '1') return { success: false, reason: 'Gagal ambil data.' };
        const tx = data.result.find(t => t.hash.toLowerCase() === txHash.toLowerCase());
        if (!tx) return { success: false, reason: 'TX ID tidak ditemukan.' };
        if (tx.contractAddress.toLowerCase() !== CONFIG.USDT_CONTRACT.toLowerCase()) return { success: false, reason: 'Bukan USDT.' };
        if (tx.to.toLowerCase() !== CONFIG.WALLET_ADDRESS.toLowerCase()) return { success: false, reason: 'Tidak ke wallet ini.' };
        const amount = parseFloat(tx.value) / 1e6;
        if (amount < expected) return { success: false, reason: `USDT ${amount} (minimal ${expected})` };
        return { success: true, amount };
    } catch(e) { return { success: false, reason: `Error: ${e.message}` }; }
}

